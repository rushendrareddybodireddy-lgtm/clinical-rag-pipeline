# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clinical_rag

# ─── LLM Provider ────────────────────────────────────────────────────────────
# Options: claude | openai
LLM_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Claude model override (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# ─── RAG Settings ─────────────────────────────────────────────────────────────
# Number of patient records to retrieve per query
TOP_K_RETRIEVAL=10

# ─── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_SECRET_KEY=change-me-in-production

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
